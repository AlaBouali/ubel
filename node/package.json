{
  "name": "@arcane-spark/ubel-node",
  "version": "0.6.0",
  "description": "Supply-chain security firewall for Node.js — resolves dependencies, scans via OSV.dev and NVD, and enforces configurable vulnerability policies before anything reaches node_modules. Also includes an AI-powered SAST engine (scan → verify → taint-trace) for source-level vulnerability detection, plus a separate malicious-code/backdoor scanner, both with JSON, HTML, and SARIF reporting.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "files": [
    "src/",
    "bin/",
    "LICENSE.md",
    "DISCLAIMER.md",
    "README.md"
  ],
  "bin": {
    "ubel-npm": "bin/npm.js",
    "ubel-pnpm": "bin/pnpm.js",
    "ubel-bun": "bin/bun.js",
    "ubel-agent": "bin/agent.js",
    "ubel-platform": "bin/platform.js",
    "ubel-sast": "bin/sast.js",
    "ubel-mal": "bin/mal.js",
    "ubel-chunk": "bin/chunk.js"
  },
  "scripts": {
    "test_sca": "node -e \"process.argv.splice(2,0,'npm','health'); import('@arcane-spark/ubel-node/sca').then(({ main }) => main())\"",
    "test_sast": "node -e \"process.argv.splice(2,0,'--help'); import('@arcane-spark/ubel-node/sast').then(({ main }) => main())\"",
    "test_mal": "node -e \"process.argv.splice(2,0,'malware','--help'); import('@arcane-spark/ubel-node/sast').then(({ main }) => main())\"",
    "test": "npm run test_sca && npm run test_sast && npm run test_mal"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "sca/main.js",
  "exports": {
    "./sca": "./sca/main.js",
    "./sast": "./sast/main.js"
  },
  "keywords": [
    "security",
    "supply-chain",
    "vulnerability",
    "audit",
    "firewall",
    "sbom",
    "osv",
    "nvd",
    "npm",
    "pnpm",
    "bun",
    "dependencies",
    "policy",
    "sca",
    "cve",
    "compliance",
    "scanner",
    "infection",
    "malware",
    "yarn",
    "devsecops",
    "cvss",
    "lockfile",
    "cyclonedx"
  ],
  "author": "Ala Bouali <ala.bouali.1997@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlaBouali/ubel.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/AlaBouali/ubel/issues"
  },
  "homepage": "https://github.com/AlaBouali/ubel#readme"
}