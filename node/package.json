{
  "name": "@arcane-spark/ubel-node",
  "version": "0.1.1",
  "description": "Supply-chain security firewall for Node.js — resolves dependencies, scans via OSV.dev and NVD, and enforces configurable vulnerability policies before anything reaches node_modules.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "files": [
    "src/",
    "bin/",
    "LICENSE.md",
    "DISCLAIMER.md",
    "README.md"
  ],
  "bin": {
    "ubel-npm": "bin/npm.js",
    "ubel-pnpm": "bin/pnpm.js",
    "ubel-bun": "bin/bun.js",
    "ubel-agent": "bin/agent.js",
    "ubel-platform": "bin/platform.js"
  },
  "scripts": {
    "test": "node src/main.js npm health"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "src/main.js",
  "exports": {
    ".": "./src/main.js"
  },
  "keywords": [
    "security",
    "supply-chain",
    "vulnerability",
