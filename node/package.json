    "dependencies",
    "policy",
    "sca",
    "cve",
    "compliance",
    "scanner",
    "infection",
    "malware",
    "yarn",
    "devsecops",
    "cvss",
    "lockfile",
    "cyclonedx"
  ],
  "author": "Ala Bouali <contact@alabouali.com>",
  "repository": {
    "type": "git",
